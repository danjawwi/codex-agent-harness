{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/danjawwi/codex-agent-harness/schemas/inspection.schema.json",
  "title": "Harness Inspection Record",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "inspection_id",
    "timestamp",
    "task_id",
    "milestone_id",
    "inspector",
    "result",
    "summary"
  ],
  "properties": {
    "inspection_id": {
      "type": "string",
      "minLength": 1
    },
    "timestamp": {
      "type": "string"
    },
    "task_id": {
      "type": "string",
      "minLength": 1
    },
    "milestone_id": {
      "type": "string",
      "minLength": 1
    },
    "inspector": {
      "type": "string",
      "minLength": 1
    },
    "result": {
      "type": "string",
      "enum": [
        "pass",
        "fail",
        "pass_with_risk"
      ]
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "acceptance_checks_reviewed": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "evidence": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "findings": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/finding"
      }
    },
    "follow_up_action": {
      "type": "string"
    }
  },
  "$defs": {
    "finding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "severity",
        "title",
        "details"
      ],
      "properties": {
        "severity": {
          "type": "string",
          "enum": [
            "low",
            "medium",
            "high",
            "critical"
          ]
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "details": {
          "type": "string",
          "minLength": 1
        },
        "recommended_fix": {
          "type": "string"
        }
      }
    }
  }
}
