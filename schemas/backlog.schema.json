{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/danjawwi/codex-agent-harness/schemas/backlog.schema.json",
  "title": "Harness Backlog",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "created_at",
    "project_goal",
    "status_values",
    "milestones",
    "features"
  ],
  "properties": {
    "version": {
      "type": "integer",
      "minimum": 1
    },
    "created_at": {
      "type": "string"
    },
    "project_goal": {
      "type": "string"
    },
    "status_values": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "milestones": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/milestone"
      }
    },
    "features": {
      "type": "array",
      "items": {
        "$ref": "./task.schema.json"
      }
    }
  },
  "$defs": {
    "milestone": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "title",
        "status",
        "goal",
        "delivery_target"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "goal": {
          "type": "string",
          "minLength": 1
        },
        "expansion_level": {
          "type": "integer",
          "minimum": 1,
          "maximum": 10
        },
        "status": {
          "type": "string",
          "enum": [
            "pending",
            "ready",
            "in_progress",
            "blocked",
            "done"
          ]
        },
        "delivery_target": {
          "type": "string",
          "minLength": 1
        },
        "review_artifact": {
          "type": "string"
        },
        "depends_on": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        },
        "acceptance_checks": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "notes": {
          "type": "string"
        }
      }
    }
  }
}
