{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/danjawwi/codex-agent-harness/schemas/branch-graph.schema.json",
  "title": "Harness Branch Graph",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "project",
    "branches"
  ],
  "properties": {
    "version": {
      "type": "integer",
      "minimum": 1
    },
    "project": {
      "type": "string",
      "minLength": 1
    },
    "branches": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/branch"
      }
    }
  },
  "$defs": {
    "branch": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "title",
        "status",
        "created_at",
        "summary"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "type": "string",
          "enum": [
            "active",
            "paused",
            "completed",
            "abandoned"
          ]
        },
        "created_at": {
          "type": "string"
        },
        "parent_branch_id": {
          "type": "string"
        },
        "parent_checkpoint_id": {
          "type": "string"
        },
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "current_milestone_id": {
          "type": "string"
        }
      }
    }
  }
}
