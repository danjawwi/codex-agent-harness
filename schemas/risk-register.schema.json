{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/danjawwi/codex-agent-harness/schemas/risk-register.schema.json",
  "title": "Harness Risk Register",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "project",
    "items"
  ],
  "properties": {
    "version": {
      "type": "integer",
      "minimum": 1
    },
    "project": {
      "type": "string",
      "minLength": 1
    },
    "items": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/risk"
      }
    }
  },
  "$defs": {
    "risk": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "severity",
        "status",
        "summary"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "severity": {
          "type": "string",
          "enum": [
            "low",
            "medium",
            "high",
            "critical"
          ]
        },
        "status": {
          "type": "string",
          "enum": [
            "open",
            "watching",
            "mitigated",
            "closed"
          ]
        },
        "milestone_id": {
          "type": "string"
        },
        "slice_id": {
          "type": "string"
        },
        "task_id": {
          "type": "string"
        },
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "mitigation": {
          "type": "string"
        }
      }
    }
  }
}
