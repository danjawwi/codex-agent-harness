{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/danjawwi/codex-agent-harness/schemas/task.schema.json",
  "title": "Harness Task",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "title",
    "status",
    "owner_role",
    "acceptance_checks"
  ],
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "summary": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "pending",
        "ready",
        "in_progress",
        "blocked",
        "done"
      ]
    },
    "owner_role": {
      "type": "string",
      "enum": [
        "project_manager",
        "requirements_manager",
        "executor",
        "inspector",
        "recorder"
      ]
    },
    "assigned_executor": {
      "type": "string"
    },
    "milestone_id": {
      "type": "string"
    },
    "depends_on": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "parallel_group": {
      "type": "string"
    },
    "acceptance_checks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "verification_plan": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "deliverables": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "notes": {
      "type": "string"
    }
  }
}
