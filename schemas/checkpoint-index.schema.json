{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/danjawwi/codex-agent-harness/schemas/checkpoint-index.schema.json",
  "title": "Harness Checkpoint Index",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "project",
    "checkpoints"
  ],
  "properties": {
    "version": {
      "type": "integer",
      "minimum": 1
    },
    "project": {
      "type": "string",
      "minLength": 1
    },
    "checkpoints": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/checkpoint"
      }
    }
  },
  "$defs": {
    "checkpoint": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "created_at",
        "trigger",
        "summary",
        "restore_hint"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "created_at": {
          "type": "string"
        },
        "milestone_id": {
          "type": "string"
        },
        "task_id": {
          "type": "string"
        },
        "branch_id": {
          "type": "string"
        },
        "trigger": {
          "type": "string",
          "minLength": 1
        },
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "restore_hint": {
          "type": "string",
          "minLength": 1
        },
        "artifact_refs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    }
  }
}
