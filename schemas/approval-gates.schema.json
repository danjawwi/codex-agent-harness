{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/danjawwi/codex-agent-harness/schemas/approval-gates.schema.json",
  "title": "Harness Approval Gates",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "project",
    "enabled",
    "gates"
  ],
  "properties": {
    "version": {
      "type": "integer",
      "minimum": 1
    },
    "project": {
      "type": "string",
      "minLength": 1
    },
    "enabled": {
      "type": "boolean"
    },
    "gates": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/gate"
      }
    }
  },
  "$defs": {
    "gate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "requested_at",
        "status",
        "action_type",
        "summary"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "requested_at": {
          "type": "string"
        },
        "status": {
          "type": "string",
          "enum": [
            "pending",
            "approved",
            "rejected",
            "changes_requested"
          ]
        },
        "action_type": {
          "type": "string",
          "minLength": 1
        },
        "milestone_id": {
          "type": "string"
        },
        "task_id": {
          "type": "string"
        },
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "decision_summary": {
          "type": "string"
        }
      }
    }
  }
}
