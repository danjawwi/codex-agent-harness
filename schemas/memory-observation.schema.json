{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/danjawwi/codex-agent-harness/schemas/memory-observation.schema.json",
  "title": "Harness Memory Observation",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "timestamp",
    "project",
    "milestone_id",
    "category",
    "summary"
  ],
  "properties": {
    "timestamp": {
      "type": "string"
    },
    "project": {
      "type": "string",
      "minLength": 1
    },
    "milestone_id": {
      "type": "string",
      "minLength": 1
    },
    "task_id": {
      "type": "string"
    },
    "category": {
      "type": "string",
      "enum": [
        "decision",
        "finding",
        "repair",
        "risk",
        "handoff",
        "result",
        "context"
      ]
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "details": {
      "type": "string"
    },
    "artifacts": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
